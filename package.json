{
  "name": "mastra-opencode",
  "version": "0.1.0",
  "description": "Use OpenCode as a Mastra SDK agent.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node --format esm --external @mastra/core --external @opencode-ai/sdk && bun build ./src/index.ts --outfile ./dist/index.cjs --target node --format cjs --external @mastra/core --external @opencode-ai/sdk && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "bun test",
    "test:live": "LIVE_OPENCODE_TEST=1 bun test test/live.test.ts --timeout 120000",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mastra/core": ">=1.34.0-0 <2.0.0-0",
    "@opencode-ai/sdk": "^1.17.11"
  },
  "devDependencies": {
    "@mastra/core": "^1.34.0",
    "@opencode-ai/sdk": "^1.17.11",
    "@types/bun": "latest",
    "@types/node": "^24.12.2",
    "typescript": "^5.8.2"
  }
}
